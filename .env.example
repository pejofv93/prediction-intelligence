# Prediction Intelligence — variables de entorno
# Copiar a .env y rellenar valores reales (NO commitear .env)

# GCP
GOOGLE_CLOUD_PROJECT=prediction-intelligence
FIRESTORE_COLLECTION_PREFIX=

# IA
GROQ_API_KEY=gsk_...
TAVILY_API_KEY=tvly-...

# Deportes
FOOTBALL_API_KEY=...                    # football-data.org
FOOTBALL_RAPID_API_KEY=...              # API-Sports / API-Football (RapidAPI)

# CoinGecko (opcional — mejora rate limits)
COINGECKO_API_KEY=

# Telegram
TELEGRAM_TOKEN=...                      # BotFather
TELEGRAM_CHAT_ID=...                    # Chat ID destino de alertas

# Dashboard
DASHBOARD_USER=admin
DASHBOARD_PASS=changeme

# URLs Cloud Run (rellenar tras primer deploy)
SPORTS_AGENT_URL=https://sports-agent-xxx-ew.a.run.app
POLY_AGENT_URL=https://polymarket-agent-xxx-ew.a.run.app
TELEGRAM_BOT_URL=https://telegram-bot-xxx-ew.a.run.app
DASHBOARD_URL=https://dashboard-xxx-ew.a.run.app

# Token de autenticacion GitHub Actions → Cloud Run
CLOUD_RUN_TOKEN=genera-un-token-aleatorio-seguro

